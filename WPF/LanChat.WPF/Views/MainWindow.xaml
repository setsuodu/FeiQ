<Window x:Class="LanChat.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LanChat.WPF.Converters"
        xmlns:models="clr-namespace:LanChat.WPF.Models"
        xmlns:vm="clr-namespace:LanChat.WPF.ViewModels"
        Title="LanChat · 局域网飞聊"
        Width="960" Height="680"
        MinWidth="720" MinHeight="480"
        Background="#F0F2F5"
        Closed="Window_Closed">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:ImageSourceConverter     x:Key="ImgConv"/>
        <conv:DirectionToAlignConverter x:Key="AlignConv"/>
        <conv:TypeToVisibilityConverter x:Key="TypeVis"/>
        <conv:FileSizeConverter         x:Key="SizeConv"/>
        <conv:DirectionToBubbleColorConverter x:Key="BubbleConv"/>

        <!-- Peer 列表项 -->
        <DataTemplate x:Key="PeerTemplate" DataType="{x:Type models:Peer}">
            <Border Padding="10,8" Background="Transparent" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EAF6"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="40" Height="40" Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="#5C6BC0"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#212121"/>
                        <TextBlock Text="{Binding IP}"   FontSize="11"          Foreground="#757575"/>
                    </StackPanel>
                    <Ellipse Width="8" Height="8" Fill="#4CAF50"
                             HorizontalAlignment="Right" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 气泡消息模板 -->
        <DataTemplate x:Key="ChatBubble" DataType="{x:Type models:ChatMessage}">
            <Border HorizontalAlignment="{Binding Direction, Converter={StaticResource AlignConv}}"
                    Margin="8,4"
                    MaxWidth="480">
                <StackPanel>
                    <!-- 发送者姓名（仅接收方显示） -->
                    <TextBlock Text="{Binding FromName}"
                               FontSize="11" Foreground="#9E9E9E" Margin="12,0,12,2"
                               Visibility="{Binding Direction, Converter={StaticResource TypeVis}, ConverterParameter=Received}"/>

                    <!-- 文字气泡 -->
                    <Border Background="{Binding Direction, Converter={StaticResource BubbleConv}}"
                            CornerRadius="12" Padding="12,8"
                            Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Text}"
                            Effect="{DynamicResource ShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                       FontSize="14" Foreground="#212121"/>
                            <TextBlock Text="{Binding TimeStr}" FontSize="10" Foreground="#BDBDBD"
                                       HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 图片气泡 -->
                    <Border Background="{Binding Direction, Converter={StaticResource BubbleConv}}"
                            CornerRadius="12" Padding="4"
                            Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Image}">
                        <StackPanel>
                            <Image Source="{Binding Content, Converter={StaticResource ImgConv}}"
                                   MaxWidth="320" MaxHeight="240" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding TimeStr}" FontSize="10" Foreground="#BDBDBD"
                                       HorizontalAlignment="Right" Margin="4,2,4,2"/>
                        </StackPanel>
                    </Border>

                    <!-- 文件气泡 -->
                    <Border Background="{Binding Direction, Converter={StaticResource BubbleConv}}"
                            CornerRadius="12" Padding="12,10" Cursor="Hand"
                            Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=FileReceived}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.OpenFileCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="28" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding FileSize, Converter={StaticResource SizeConv}}"
                                           FontSize="11" Foreground="#757575"/>
                                <TextBlock Text="点击打开所在文件夹" FontSize="10" Foreground="#42A5F5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 已发送文件气泡 -->
                    <Border Background="{Binding Direction, Converter={StaticResource BubbleConv}}"
                            CornerRadius="12" Padding="12,10"
                            Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=FileRequest}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📤" FontSize="28" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding FileSize, Converter={StaticResource SizeConv}}"
                                           FontSize="11" Foreground="#757575"/>
                                <TextBlock Text="已发送" FontSize="10" Foreground="#66BB6A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 阴影效果 -->
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="6" ShadowDepth="1"
                          Color="#BDBDBD" Direction="270" Opacity="0.3"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── 左栏：在线用户 ── -->
        <Border Grid.Column="0" Background="White">
            <DockPanel>
                <!-- 顶栏 -->
                <Border DockPanel.Dock="Top" Background="#3F51B5" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="LanChat" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding MyName}" FontSize="12" Foreground="#C5CAE9"/>
                    </StackPanel>
                </Border>

                <!-- 搜索提示 -->
                <TextBlock DockPanel.Dock="Top"
                           Text="局域网内在线用户"
                           Margin="12,10,12,4" FontSize="11" Foreground="#9E9E9E"/>

                <!-- 用户列表 -->
                <ListBox ItemsSource="{Binding Peers}"
                         SelectedItem="{Binding SelectedPeer}"
                         ItemTemplate="{StaticResource PeerTemplate}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- 分割线 -->
        <GridSplitter Grid.Column="1" Width="1" Background="#E0E0E0" ResizeBehavior="PreviousAndNext"/>

        <!-- ── 右栏：聊天区 ── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <TextBlock Text="{Binding SelectedPeer.Name, FallbackValue='请选择联系人'}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#212121" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" DockPanel.Dock="Right"
                               FontSize="12" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- 消息列表 -->
            <ScrollViewer Grid.Row="1" x:Name="MsgScroller"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,8">
                <ItemsControl ItemsSource="{Binding Messages}"
                              ItemTemplate="{StaticResource ChatBubble}"
                              Background="Transparent"/>
            </ScrollViewer>

            <!-- 工具栏 -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="🖼️ 图片" Click="SendImage_Click"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" Padding="10,6" Cursor="Hand"
                            Foreground="#5C6BC0" ToolTip="发送图片"/>
                    <Button Content="📎 文件" Click="SendFile_Click"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" Padding="10,6" Cursor="Hand"
                            Foreground="#5C6BC0" ToolTip="发送文件"/>
                </StackPanel>
            </Border>

            <!-- 输入区 -->
            <Border Grid.Row="3" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             BorderThickness="0" FontSize="14"
                             KeyDown="Input_KeyDown"
                             VerticalScrollBarVisibility="Auto"
                             Foreground="#212121"
                             VerticalContentAlignment="Top"
                             Padding="4"/>
                    <Button Grid.Column="1" Content="发送"
                            Command="{Binding SendTextCommand}"
                            Background="#3F51B5" Foreground="White"
                            BorderThickness="0" FontSize="14"
                            Margin="8,0,0,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 未选择提示遮罩 -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    Background="#F0F2F5"
                    Visibility="{Binding SelectedPeer, Converter={StaticResource TypeVis}, ConverterParameter=Null}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="选择左侧联系人开始聊天" Foreground="#9E9E9E"
                               FontSize="16" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
